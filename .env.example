PORT=8000
APP_ENV=development
DATABASE_URL=mysql+pymysql://user:password@host:3306/database
TELEGRAM_BOT_TOKEN=replace-me
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-string
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-mini-app.example.com
BOT_USERNAME=mistressbjqueenbot
CMS_API_URL=https://telegram-cms.mistressbjqueen.com
CMS_API_TOKEN=change-me
CMS_TRACKING_TIMEOUT_SECONDS=4
TRACKING_LINKS_BASE_URL=https://links.mistressbjqueen.com
TRACKING_CLIP_STREAM_SLUG=
TRACKING_CLIP_DOWNLOAD_SLUG=
TRACKING_PRODUCT_BUY_SLUG=
FEATURED_TIER_PRODUCT_IDS=26,23,21
BUNNY_STREAM_LIBRARY_ID=your-library-id
BUNNY_STREAM_API_KEY=your-bunny-stream-api-key
